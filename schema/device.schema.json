{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "device.schema.json",
  "title": "Device",
  "type": "object",
  "required": ["name", "role", "vendor", "model"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "vendor": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
      }
    }
  }
}
